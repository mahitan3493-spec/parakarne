rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function validCategoryValue(categories, key) {
      return !(key in categories)
        || (categories[key] is int && categories[key] >= 1 && categories[key] <= 5);
    }

    function validApplicationOutcome(value) {
      return value == 'approved'
        || value == 'rejected'
        || value == 'not_applied';
    }

    function validEmploymentStatus(value) {
      return value == 'private_sector'
        || value == 'public_sector'
        || value == 'self_employed'
        || value == 'retired'
        || value == 'not_working'
        || value == 'student'
        || value == 'business_owner';
    }

    function validFindeksScoreRange(value) {
      return value == 'unknown'
        || value == '0_699'
        || value == '700_1099'
        || value == '1100_1299'
        || value == '1300_1499'
        || value == '1500_1699'
        || value == '1700_1900';
    }

    match /banks/{bankId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.token.email_verified == true
        && reviewId == request.auth.uid + '_' + request.resource.data.bankId
        && request.resource.data.keys().hasOnly([
          'uid',
          'userName',
          'bankId',
          'bankName',
          'stars',
          'categories',
          'creditOutcome',
          'creditApplicationOutcome',
          'creditCardApplicationOutcome',
          'employmentStatus',
          'findeksScoreRange',
          'text',
          'note',
          'status',
          'reportCount',
          'reportedBy',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.userName.size() >= 1
        && request.resource.data.userName.size() <= 80
        && request.resource.data.bankId is string
        && request.resource.data.bankId.size() >= 2
        && request.resource.data.bankId.size() <= 80
        && request.resource.data.bankName is string
        && request.resource.data.bankName.size() >= 2
        && request.resource.data.bankName.size() <= 80
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5
        && request.resource.data.categories is map
        && request.resource.data.categories.keys().hasOnly([
          'branch',
          'service',
          'app',
          'atm',
          'security'
        ])
        && request.resource.data.categories.keys().hasAll([
          'service',
          'app',
          'security'
        ])
        && validCategoryValue(request.resource.data.categories, 'branch')
        && validCategoryValue(request.resource.data.categories, 'service')
        && validCategoryValue(request.resource.data.categories, 'app')
        && validCategoryValue(request.resource.data.categories, 'atm')
        && validCategoryValue(request.resource.data.categories, 'security')
        && (!('creditOutcome' in request.resource.data)
          || request.resource.data.creditOutcome in ['approved', 'conditional', 'rejected'])
        && (!('creditApplicationOutcome' in request.resource.data)
          || validApplicationOutcome(request.resource.data.creditApplicationOutcome))
        && (!('creditCardApplicationOutcome' in request.resource.data)
          || validApplicationOutcome(request.resource.data.creditCardApplicationOutcome))
        && (!('employmentStatus' in request.resource.data)
          || validEmploymentStatus(request.resource.data.employmentStatus))
        && (!('findeksScoreRange' in request.resource.data)
          || validFindeksScoreRange(request.resource.data.findeksScoreRange))
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 25
        && request.resource.data.text.size() <= 1000
        && request.resource.data.note == 'Bu yorum karne ortalamasına eklendi.'
        && request.resource.data.status == 'published'
        && request.resource.data.reportCount == 0
        && request.resource.data.reportedBy is list
        && request.resource.data.reportedBy.size() == 0
        && request.resource.data.createdAt == request.time;

      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid != resource.data.uid
          && resource.data.status == 'published'
          && !(request.auth.uid in resource.data.reportedBy)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reportCount',
            'reportedBy'
          ])
          && request.resource.data.reportCount == resource.data.reportCount + 1
          && request.resource.data.reportedBy.size() == resource.data.reportedBy.size() + 1
          && request.resource.data.reportedBy.hasAll(resource.data.reportedBy)
          && request.auth.uid in request.resource.data.reportedBy
        );

      allow delete: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid == resource.data.uid
        );
    }
  }
}
